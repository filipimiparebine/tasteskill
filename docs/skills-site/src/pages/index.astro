---
import BaseLayout from "../layouts/BaseLayout.astro";
import { families, skills, skillsByFamily } from "../data/skills";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<BaseLayout title="Skills Atlas — Claude Code skills reference">
  <div class="wrap">
    <section class="hero">
      <h1>Skills Atlas</h1>
      <p>
        A reference for the <span class="count">{skills.length} skills</span> installed
        in this repo. Browse by purpose, see what each one does and how it looks, and
        decide which fits the project in front of you.
      </p>
    </section>

    {families.map((fam) => (
      <section class="fam-block" style={`--fam: var(--fam-${fam.id})`}>
        <div class="fam-head">
          <h2>{fam.name}</h2>
          <span class="n">{skillsByFamily(fam.id).length} skills</span>
        </div>
        <p class="fam-blurb">{fam.blurb}</p>
        <div class="cards">
          {skillsByFamily(fam.id).map((s) => (
            <a class="card" href={`${base}/skills/${s.slug}/`}>
              <h3>{s.name}</h3>
              <p>{s.tagline}</p>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
  <footer class="site">
    Generated from <code>.claude/skills/</code>. Prototype — {skills.length} skills catalogued,
    2 pages fully realised (minimalist-ui, tdd).
  </footer>
</BaseLayout>
