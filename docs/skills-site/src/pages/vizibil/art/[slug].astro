---
import ArtLayout from "../../../layouts/ArtLayout.astro";
import ArtCard from "../../../components/art/ArtCard.astro";
import Avatar from "../../../components/art/Avatar.astro";
import WatercolorArt from "../../../components/art/WatercolorArt.astro";
import Tr from "../../../components/art/Tr.astro";
import { artworks, getArtist, worksByArtist } from "../../../data/art";
export function getStaticPaths() {
  return artworks.map((w) => ({ params: { slug: w.slug }, props: { work: w } }));
}
const { work } = Astro.props;
const artist = getArtist(work.artist);
const more = worksByArtist(artist.slug).filter((w) => w.slug !== work.slug).slice(0, 3);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const sold = work.status === "sold";
---
<ArtLayout title={`${work.title} — ${artist.name}`} current="galerie">
  <section class="aq-section aq-art-page">
    <a class="aq-back" href={`${base}/vizibil/gallery/`}><Tr k="back.gallery" /></a>
    <div class="aq-art-stage">
      <div class="aq-art-canvas">
        <WatercolorArt seed={work.seed} palette={work.palette} blobs={7} />
        {sold && <span class="aq-art-sold"><Tr k="status.sold" /></span>}
      </div>
      <aside class="aq-art-panel">
        <p class="aq-kicker">{work.medium} · {work.year}</p>
        <h1 class="aq-art-title">{work.title}</h1>
        <a class="aq-art-artist" href={`${base}/vizibil/artist/${artist.slug}/`}>
          <Avatar initials={artist.initials} palette={artist.palette} seed={work.seed} size={40} />
          <span><b>{artist.name}</b><em>{artist.city}</em></span>
        </a>
        <dl class="aq-art-specs">
          <div><dt><Tr k="artwork.medium" /></dt><dd>{work.medium}</dd></div>
          <div><dt><Tr k="artwork.category" /></dt><dd>{work.themes.join(", ")}</dd></div>
          <div><dt><Tr k="artwork.size" /></dt><dd>40 × 50 cm</dd></div>
          <div><dt><Tr k="artwork.year" /></dt><dd>{work.year}</dd></div>
        </dl>
        <div class="aq-art-buy">
          {sold
            ? <span class="aq-art-price aq-art-price-sold"><Tr k="status.sold" /></span>
            : <span class="aq-art-price">{work.priceRON} lei</span>}
          <div class="aq-art-actions">
            {!sold && <a class="aq-btn aq-btn-primary aq-buy" href="#" data-mock><Tr k="cta.buy_now" /></a>}
            <a class="aq-btn aq-btn-ghost" href="#" data-mock><Tr k="cta.support_artist" /></a>
            <a class="aq-btn aq-btn-ghost" href={`${base}/vizibil/donate/`}><Tr k="nav.donate" /></a>
          </div>
          <p class="aq-art-note"><Tr k="artwork.note" /></p>
        </div>
      </aside>
    </div>
  </section>

  {more.length > 0 && (
    <section class="aq-section">
      <div class="aq-shead"><h2 class="aq-stitle">{artist.alias}</h2></div>
      <div class="aq-rows">{more.map((w) => <ArtCard work={w} />)}</div>
    </section>
  )}
</ArtLayout>
