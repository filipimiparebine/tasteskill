---
import ArtLayout from "../../../layouts/ArtLayout.astro";
import ArtCard from "../../../components/art/ArtCard.astro";
import { artworks, mediums, themeTags } from "../../../data/art";
---
<ArtLayout title="Galerie — Aquarelă" current="galerie">
  <section class="aq-section aq-gallery">
    <div class="aq-gal-head">
      <h1 class="aq-page-title">Galerie</h1>
      <p class="aq-page-sub">{artworks.length} lucrări disponibile. Alege un artist, o temă sau un mediu.</p>
    </div>

    <div class="aq-filters">
      <div class="aq-filter-group" data-axis="medium">
        <span class="aq-filter-label">Mediu</span>
        <button class="aq-filter is-on" data-val="__all">Toate</button>
        {mediums.map((m) => <button class="aq-filter" data-val={m}>{m}</button>)}
      </div>
      <div class="aq-filter-group" data-axis="theme">
        <span class="aq-filter-label">Temă</span>
        <button class="aq-filter is-on" data-val="__all">Toate</button>
        {themeTags.map((t) => <button class="aq-filter" data-val={t}>{t}</button>)}
      </div>
    </div>

    <div class="aq-grid" id="aq-gal-grid">
      {artworks.map((w) => (
        <div class="aq-cell" data-medium={w.medium} data-themes={w.themes.join("|")}>
          <ArtCard work={w} />
        </div>
      ))}
    </div>
    <p class="aq-empty" id="aq-empty" hidden>Nicio lucrare pentru filtrele alese.</p>
  </section>

  <script is:inline>
    (function () {
      const state = { medium: "__all", theme: "__all" };
      const cells = [...document.querySelectorAll("#aq-gal-grid .aq-cell")];
      const empty = document.getElementById("aq-empty");
      function refresh() {
        let shown = 0;
        cells.forEach((c) => {
          const m = c.getAttribute("data-medium");
          const themes = (c.getAttribute("data-themes") || "").split("|");
          const ok = (state.medium === "__all" || m === state.medium) &&
                     (state.theme === "__all" || themes.includes(state.theme));
          c.hidden = !ok;
          if (ok) shown++;
        });
        if (empty) empty.hidden = shown !== 0;
      }
      document.querySelectorAll(".aq-filter-group").forEach((group) => {
        const axis = group.getAttribute("data-axis");
        group.querySelectorAll(".aq-filter").forEach((btn) => {
          btn.addEventListener("click", () => {
            group.querySelectorAll(".aq-filter").forEach((b) => b.classList.remove("is-on"));
            btn.classList.add("is-on");
            state[axis] = btn.getAttribute("data-val");
            refresh();
          });
        });
      });
    })();
  </script>
</ArtLayout>
