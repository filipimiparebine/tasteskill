---
import ArtLayout from "../../layouts/ArtLayout.astro";
import ArtCard from "../../components/art/ArtCard.astro";
import Avatar from "../../components/art/Avatar.astro";
import WatercolorArt from "../../components/art/WatercolorArt.astro";
import { org, artworks, artists, posts } from "../../data/art";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const featured = artworks.slice(0, 6);
const heroArt = artworks.slice(0, 3);
---
<ArtLayout title={`${org.name} — colectiv de artă din Cluj`} current="acasa">
  <section class="aq-hero">
    <div class="aq-hero-copy">
      <p class="aq-kicker">{org.kicker}</p>
      <h1 class="aq-hero-title">{org.tagline}</h1>
      <p class="aq-hero-sub">{org.about}</p>
      <div class="aq-hero-actions">
        <a class="aq-btn aq-btn-primary" href={`${base}/aquarela/gallery/`}>Vezi galeria</a>
        <a class="aq-btn aq-btn-ghost" href={`${base}/aquarela/blog/`}>Evenimente</a>
      </div>
    </div>
    <div class="aq-hero-collage">
      {heroArt.map((w, i) => (
        <a class={`aq-hero-piece p${i}`} href={`${base}/aquarela/art/${w.slug}/`}>
          <WatercolorArt seed={w.seed} palette={w.palette} />
        </a>
      ))}
    </div>
  </section>

  <section class="aq-section">
    <div class="aq-shead">
      <h2 class="aq-stitle">Lucrări noi</h2>
      <a class="aq-slink" href={`${base}/aquarela/gallery/`}>Toată galeria →</a>
    </div>
    <div class="aq-grid">
      {featured.map((w) => <ArtCard work={w} />)}
    </div>
  </section>

  <section class="aq-section aq-artists">
    <div class="aq-shead"><h2 class="aq-stitle">Artiștii colectivului</h2></div>
    <div class="aq-artist-row">
      {artists.map((a, i) => (
        <a class="aq-artist-chip" href={`${base}/aquarela/artist/${a.slug}/`}>
          <Avatar initials={a.initials} palette={a.palette} seed={i * 13 + 2} size={72} />
          <b>{a.alias}</b>
          <span>{a.media[0]}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="aq-section">
    <div class="aq-shead">
      <h2 class="aq-stitle">Din jurnal</h2>
      <a class="aq-slink" href={`${base}/aquarela/blog/`}>Tot jurnalul →</a>
    </div>
    <div class="aq-events">
      {posts.slice(0, 2).map((p) => (
        <a class="aq-event" href={`${base}/aquarela/blog/`}>
          <span class="aq-event-thumb"><WatercolorArt seed={p.seed} palette={p.palette} blobs={4} /></span>
          <div>
            <span class="aq-tag">{p.kind}</span>
            <h3>{p.title}</h3>
            <p>{p.excerpt}</p>
            <time>{p.date}</time>
          </div>
        </a>
      ))}
    </div>
  </section>
</ArtLayout>
