---
const { skill } = Astro.props;
---
<div class="v-setup-matt-pocock-skills">
  <div class="head">
    <div class="t">Skills configured</div>
    <div class="s">4 of 4 · repo ready for agents</div>
  </div>
  <div class="item"><span class="ck">✓</span><span class="k">Issue tracker</span><span class="val">GitHub</span></div>
  <div class="item"><span class="ck">✓</span><span class="k">Triage labels</span><span class="val">defaults</span></div>
  <div class="item"><span class="ck">✓</span><span class="k">Domain docs</span><span class="val">single-context</span></div>
  <div class="item"><span class="ck">✓</span><span class="k">Config file</span><span class="val">CLAUDE.md</span></div>
  <div class="foot"><span class="path">./CLAUDE.md</span> written · <span class="path">docs/agents/</span> populated</div>
</div>
<style>
  .v-setup-matt-pocock-skills{width:780px;box-sizing:border-box;padding:26px;background:#faf9f6;color:#17150f;font-family:system-ui,sans-serif;}
  .head{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:18px;}
  .head .t{font-family:"Newsreader",serif;font-size:21px;font-weight:600;}
  .head .s{font-family:"JetBrains Mono",monospace;font-size:12px;color:#1f7a45;}
  .item{display:flex;align-items:center;gap:14px;background:#fff;border:1px solid #e5e1d8;border-radius:8px;padding:13px 16px;margin-bottom:10px;}
  .ck{width:22px;height:22px;flex:none;display:flex;align-items:center;justify-content:center;border-radius:6px;background:#1f9d55;color:#fff;font-size:13px;font-weight:700;}
  .k{flex:1;font-size:14px;font-weight:600;}
  .val{font-family:"JetBrains Mono",monospace;font-size:12.5px;color:#2a271f;background:#f0ece2;padding:4px 11px;border-radius:20px;}
  .foot{margin-top:16px;font-size:12px;color:#6b6559;text-align:center;}
  .path{font-family:"JetBrains Mono",monospace;color:#2a271f;}
</style>
