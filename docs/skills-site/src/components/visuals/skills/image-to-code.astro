---
const { skill } = Astro.props;
---
<div class="v-image-to-code">
  <div class="ic-split">
    <div class="ic-col">
      <p class="ic-label">Generated design</p>
      <div class="ic-comp">
        <div class="ic-nav"><span></span><span class="ic-navpill"></span></div>
        <div class="ic-heroline ic-w65"></div>
        <div class="ic-heroline ic-w40"></div>
        <div class="ic-btn"></div>
        <div class="ic-thumb"></div>
      </div>
    </div>
    <div class="ic-arrow">
      <svg viewBox="0 0 40 24" width="40" height="24" aria-hidden="true">
        <path d="M2 12 H34 M26 5 L35 12 L26 19" fill="none" stroke="#b4552d" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span>match</span>
    </div>
    <div class="ic-col">
      <p class="ic-label">Implemented markup</p>
      <pre class="ic-code"><code><span class="ic-t">&lt;section</span> <span class="ic-a">class</span>=<span class="ic-s">"hero"</span><span class="ic-t">&gt;</span>
  <span class="ic-t">&lt;nav&gt;</span>Fjord<span class="ic-t">&lt;/nav&gt;</span>
  <span class="ic-t">&lt;h1&gt;</span>Ship the map,
    not the maze<span class="ic-t">&lt;/h1&gt;</span>
  <span class="ic-t">&lt;p&gt;</span>Design references,
    coded 1:1.<span class="ic-t">&lt;/p&gt;</span>
  <span class="ic-t">&lt;a</span> <span class="ic-a">class</span>=<span class="ic-s">"cta"</span><span class="ic-t">&gt;</span>Get early
    access<span class="ic-t">&lt;/a&gt;</span>
<span class="ic-t">&lt;/section&gt;</span></code></pre>
    </div>
  </div>
</div>

<style>
  .v-image-to-code {
    background: #fbfaf6; color: #17150f; padding: 26px 28px;
    font-family: "Newsreader", Georgia, serif; border: 1px solid #e7e3d8; border-radius: 8px;
  }
  .ic-split { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 16px; }
  .ic-col { min-width: 0; }
  .ic-label { margin: 0 0 10px; font-family: "JetBrains Mono", monospace; font-size: 10px; letter-spacing: .1em; text-transform: uppercase; color: #9a927f; }
  .ic-comp { background: linear-gradient(150deg,#2b3340,#49556a); border-radius: 8px; padding: 16px; height: 214px; position: relative; }
  .ic-nav { display: flex; justify-content: space-between; align-items: center; margin-bottom: 22px; }
  .ic-nav span { display: block; }
  .ic-nav span:first-child { width: 40px; height: 9px; border-radius: 3px; background: rgba(255,255,255,.85); }
  .ic-navpill { width: 30px; height: 12px; border-radius: 999px; background: #c9a24a; }
  .ic-heroline { height: 12px; border-radius: 4px; background: rgba(255,255,255,.9); margin-bottom: 8px; }
  .ic-w65 { width: 68%; } .ic-w40 { width: 42%; opacity: .6; }
  .ic-btn { width: 76px; height: 20px; border-radius: 6px; background: #c9a24a; margin-top: 12px; }
  .ic-thumb { position: absolute; right: 16px; bottom: 16px; width: 74px; height: 52px; border-radius: 6px; background: linear-gradient(135deg,#6b8f7d,#9cbaad); }
  .ic-arrow { display: flex; flex-direction: column; align-items: center; gap: 4px; }
  .ic-arrow span { font-family: "JetBrains Mono", monospace; font-size: 9px; text-transform: uppercase; letter-spacing: .08em; color: #b4552d; }
  .ic-code { margin: 0; background: #14130f; border-radius: 8px; padding: 14px 15px; height: 214px; overflow: hidden; font-family: "JetBrains Mono", monospace; font-size: 11px; line-height: 1.55; color: #d7d2c4; }
  .ic-t { color: #6b8f7d; } .ic-a { color: #c9a24a; } .ic-s { color: #d99a6c; }
</style>
