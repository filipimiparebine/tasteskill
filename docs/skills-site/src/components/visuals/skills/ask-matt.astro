---
const { skill } = Astro.props;
---
<div class="v-ask-matt">
  <div class="am-ask">
    <span class="am-you">you</span>
    <p class="am-q">I have a vague idea and a messy codebase — where do I even start?</p>
  </div>
  <p class="am-lead">Three ways in. Best match first.</p>
  <div class="am-routes">
    <a class="am-route am-best">
      <span class="am-badge">best match</span>
      <span class="am-skill">→ wayfinder</span>
      <span class="am-why">Map the terrain before touching code. Surface the frontier tickets.</span>
    </a>
    <a class="am-route">
      <span class="am-skill">→ research</span>
      <span class="am-why">If the unknowns are external — an API, a library, a spec you haven't read.</span>
    </a>
    <a class="am-route">
      <span class="am-skill">→ prototype</span>
      <span class="am-why">If the idea itself is the risk. Build a throwaway to feel it out.</span>
    </a>
  </div>
</div>

<style>
  .v-ask-matt {
    padding: 26px; background: #faf9f6; font-family: var(--font-sans, system-ui);
    color: #17150f; border-radius: 10px;
  }
  .am-ask {
    display: flex; gap: 12px; align-items: baseline;
    padding: 14px 16px; background: #fff; border: 1px solid #e7e3d8;
    border-radius: 10px; box-shadow: inset 0 0 0 3px #faf9f6, 0 1px 0 #f0ece2;
  }
  .am-you {
    font-family: var(--font-mono); font-size: 11px; letter-spacing: .06em;
    color: #8f897b; text-transform: uppercase; padding-top: 2px;
  }
  .am-q { margin: 0; font-family: var(--font-serif); font-size: 18px; line-height: 1.4; color: #221f18; }
  .am-lead { margin: 18px 4px 10px; font-size: 12.5px; color: #8f897b; letter-spacing: .02em; }
  .am-routes { display: flex; flex-direction: column; gap: 8px; }
  .am-route {
    position: relative; display: grid; grid-template-columns: 132px 1fr; gap: 6px 16px;
    padding: 13px 16px; background: #fff; border: 1px solid #e7e3d8; border-radius: 8px;
    align-items: baseline;
  }
  .am-best { border-color: #e0a37c; box-shadow: 0 0 0 1px #e0a37c, 0 2px 10px rgba(180,85,45,.08); }
  .am-badge {
    position: absolute; top: -9px; right: 14px; font-family: var(--font-mono);
    font-size: 10px; letter-spacing: .05em; text-transform: uppercase;
    background: #b4552d; color: #fff; padding: 2px 8px; border-radius: 999px;
  }
  .am-skill { font-family: var(--font-mono); font-size: 14px; font-weight: 600; color: #b4552d; }
  .am-why { font-size: 13.5px; line-height: 1.5; color: #5b564a; }
</style>
