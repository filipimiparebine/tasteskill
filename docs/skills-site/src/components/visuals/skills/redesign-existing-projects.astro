---
const { skill } = Astro.props;
---
<div class="v-redesign-existing-projects">
  <div class="rep-side rep-before">
    <div class="rep-b-nav"><span></span><span></span><span></span></div>
    <div class="rep-b-hero">
      <p class="rep-b-h">Welcome To Our Website</p>
      <p class="rep-b-p">We provide solutions for your business needs today.</p>
      <button class="rep-b-btn">Click Here</button>
    </div>
    <div class="rep-b-cards"><i></i><i></i><i></i></div>
  </div>

  <div class="rep-divider">
    <span class="rep-lbl rep-lbl-b">before</span>
    <span class="rep-line"></span>
    <span class="rep-lbl rep-lbl-a">after</span>
  </div>

  <div class="rep-side rep-after">
    <div class="rep-a-nav">
      <span class="rep-a-mark">◆ Meridian</span>
      <span class="rep-a-cta">Book a call</span>
    </div>
    <div class="rep-a-hero">
      <p class="rep-a-kick">Operations, refined</p>
      <h3 class="rep-a-h">Run the whole<br/>business from<br/><em>one surface.</em></h3>
      <a class="rep-a-btn" href="#">Start free →</a>
    </div>
    <div class="rep-a-cards"><i></i><i></i><i></i></div>
  </div>
</div>

<style>
  .v-redesign-existing-projects {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    min-height: 380px;
    background: #faf9f6;
    font-family: "Newsreader", Georgia, serif;
    overflow: hidden;
  }
  .rep-side { padding: 20px; display: flex; flex-direction: column; }

  /* BEFORE */
  .rep-before { background: #ffffff; }
  .rep-b-nav { display: flex; gap: 8px; margin-bottom: 24px; }
  .rep-b-nav span { width: 34px; height: 8px; background: #d6d6d6; border-radius: 2px; }
  .rep-b-hero { text-align: center; }
  .rep-b-h { margin: 0 0 8px; font-family: Arial, sans-serif; font-size: 20px; font-weight: 700; color: #333; }
  .rep-b-p { margin: 0 0 16px; font-family: Arial, sans-serif; font-size: 12px; color: #888; line-height: 1.3; }
  .rep-b-btn { font-family: Arial, sans-serif; font-size: 11px; background: #4a72d0; color: #fff; border: none; padding: 8px 16px; border-radius: 3px; }
  .rep-b-cards { display: flex; gap: 8px; margin-top: auto; }
  .rep-b-cards i { flex: 1; height: 46px; background: #ededed; border: 1px solid #e0e0e0; border-radius: 3px; }

  /* DIVIDER */
  .rep-divider { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10px; padding: 0 6px; background: #f0ede4; }
  .rep-line { width: 1px; flex: 1; background: #d8d2c2; }
  .rep-lbl { font-family: "JetBrains Mono", monospace; font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; writing-mode: vertical-rl; transform: rotate(180deg); padding: 8px 0; }
  .rep-lbl-b { color: #a8a291; }
  .rep-lbl-a { color: #17150f; }

  /* AFTER */
  .rep-after { background: #f5f2ea; }
  .rep-a-nav { display: flex; justify-content: space-between; align-items: center; margin-bottom: 34px; }
  .rep-a-mark { font-family: "JetBrains Mono", monospace; font-size: 11px; letter-spacing: 0.02em; color: #17150f; }
  .rep-a-cta { font-family: "JetBrains Mono", monospace; font-size: 10px; color: #7d7869; border: 1px solid #d8d2c2; border-radius: 999px; padding: 4px 11px; }
  .rep-a-kick { margin: 0 0 12px; font-family: "JetBrains Mono", monospace; font-size: 10px; letter-spacing: 0.09em; text-transform: uppercase; color: #948d7c; }
  .rep-a-h { margin: 0; font-size: 30px; line-height: 1.05; font-weight: 500; letter-spacing: -0.025em; color: #17150f; }
  .rep-a-h em { font-style: italic; font-weight: 400; }
  .rep-a-btn { display: inline-block; margin-top: 20px; font-family: "JetBrains Mono", monospace; font-size: 12px; color: #f5f2ea; background: #17150f; text-decoration: none; padding: 11px 22px; border-radius: 2px; }
  .rep-a-cards { display: flex; gap: 10px; margin-top: auto; }
  .rep-a-cards i { flex: 1; height: 46px; background: #fffdf8; border: 1px solid #e6e0d1; border-radius: 6px; box-shadow: 0 6px 16px -10px rgba(30,25,15,.25); }
</style>
