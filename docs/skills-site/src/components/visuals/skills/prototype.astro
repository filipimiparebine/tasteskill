---
const { skill } = Astro.props;
---
<div class="v-prototype">
  <span class="pt-label">rough — throwaway</span>
  <div class="pt-frame">
    <div class="pt-bar">
      <span class="pt-logo">▢ logo</span>
      <span class="pt-nav">nav · nav · nav</span>
    </div>
    <div class="pt-grid">
      <div class="pt-hero">
        <div class="pt-lines"><i style="width:80%"></i><i style="width:64%"></i><i style="width:72%"></i></div>
        <div class="pt-btn">do the thing →</div>
      </div>
      <div class="pt-img"><span>image?</span></div>
    </div>
    <div class="pt-cards">
      <div class="pt-card"><i></i><i style="width:60%"></i></div>
      <div class="pt-card"><i></i><i style="width:60%"></i></div>
      <div class="pt-card"><i></i><i style="width:60%"></i></div>
    </div>
    <p class="pt-note">? does the 3-up feel too dense — try 2-up next</p>
  </div>
</div>

<style>
  .v-prototype {
    position: relative; padding: 30px 26px 26px; background: #faf9f6; border-radius: 8px;
    font-family: var(--font-mono); color: #6b6558;
  }
  .pt-label {
    position: absolute; top: 12px; right: 16px; font-size: 11px; letter-spacing: .04em;
    color: #a8412a; transform: rotate(-2deg); background: #fbede4; padding: 3px 9px;
    border: 1px dashed #e0a98f; border-radius: 4px;
  }
  .pt-frame {
    border: 2.5px dashed #b8b2a3; border-radius: 10px; padding: 16px;
    background: repeating-linear-gradient(-45deg,#fff,#fff 9px,#fbfaf7 9px,#fbfaf7 18px);
  }
  .pt-bar {
    display: flex; justify-content: space-between; align-items: center;
    border: 2px dashed #c3bdad; border-radius: 6px; padding: 8px 12px; margin-bottom: 12px; font-size: 12px;
  }
  .pt-logo { font-weight: 600; color: #57523f; }
  .pt-grid { display: grid; grid-template-columns: 1fr 150px; gap: 12px; margin-bottom: 12px; }
  .pt-hero { border: 2px dashed #c3bdad; border-radius: 6px; padding: 14px; }
  .pt-lines { display: flex; flex-direction: column; gap: 7px; margin-bottom: 14px; }
  .pt-lines i { height: 9px; background: #e4dfd2; border-radius: 3px; display: block; }
  .pt-btn {
    display: inline-block; border: 2px dashed #9c8f6f; border-radius: 6px;
    padding: 7px 14px; font-size: 12px; color: #7a6c48; background: #f6f0e2;
  }
  .pt-img {
    border: 2px dashed #c3bdad; border-radius: 6px; display: grid; place-items: center;
    color: #a8a293; font-size: 12px; font-style: italic;
    background: linear-gradient(135deg,transparent 47%,#d8d2c3 47%,#d8d2c3 53%,transparent 53%);
  }
  .pt-cards { display: grid; grid-template-columns: repeat(3,1fr); gap: 10px; }
  .pt-card { border: 2px dashed #c3bdad; border-radius: 6px; padding: 10px; display: flex; flex-direction: column; gap: 6px; }
  .pt-card i { height: 8px; background: #e4dfd2; border-radius: 3px; display: block; }
  .pt-card i:first-child { width: 100%; height: 30px; }
  .pt-note { margin: 12px 2px 0; font-size: 12px; color: #a8412a; font-style: italic; }
  @media (max-width: 620px) { .pt-grid { grid-template-columns: 1fr; } }
</style>
