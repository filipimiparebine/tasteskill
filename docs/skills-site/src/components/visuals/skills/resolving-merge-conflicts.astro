---
const { skill } = Astro.props;
---
<div class="v-resolving-merge-conflicts">
  <div class="file">src/config/retry.ts</div>
  <div class="conflict">
    <div class="m open">&lt;&lt;&lt;&lt;&lt;&lt;&lt; HEAD</div>
    <div class="line ours">const maxRetries = 3;</div>
    <div class="m mid">=======</div>
    <div class="line theirs">const maxRetries = 5;</div>
    <div class="m close">&gt;&gt;&gt;&gt;&gt;&gt;&gt; feat/backoff</div>
  </div>
  <div class="resolved">
    <div class="rhead"><span class="chk">✓</span>Resolved — keep higher ceiling, add backoff</div>
    <div class="line">const maxRetries = 5;</div>
    <div class="line">const backoff = exponential(&#123; base: 200 &#125;);</div>
  </div>
</div>
<style>
  .v-resolving-merge-conflicts{width:780px;box-sizing:border-box;padding:26px;background:#faf9f6;color:#17150f;font-family:"JetBrains Mono",monospace;}
  .file{font-size:12px;color:#6b6559;margin-bottom:12px;}
  .conflict,.resolved{border-radius:8px;overflow:hidden;font-size:13px;}
  .conflict{border:1px solid #e5e1d8;}
  .m{padding:6px 14px;font-size:12px;font-weight:600;}
  .open,.mid{background:#fbe9e7;color:#c0392b;}
  .close{background:#e7f0fb;color:#2c6fb0;}
  .line{padding:8px 14px;background:#fff;}
  .ours{background:#f2fbf5;}
  .theirs{background:#eef4fb;}
  .resolved{margin-top:16px;border:1px solid #cfe9d6;}
  .rhead{display:flex;align-items:center;gap:10px;background:#f2fbf5;padding:10px 14px;font-family:system-ui,sans-serif;font-size:13px;font-weight:600;color:#1f7a45;border-bottom:1px solid #cfe9d6;}
  .chk{width:19px;height:19px;flex:none;display:flex;align-items:center;justify-content:center;border-radius:50%;background:#1f9d55;color:#fff;font-size:12px;}
  .resolved .line{background:#fbfdfb;}
</style>
