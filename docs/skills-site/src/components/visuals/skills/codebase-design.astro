---
const { skill } = Astro.props;
---
<div class="v-codebase-design">
  <div class="caption">narrow interface · deep implementation</div>
  <div class="module">
    <div class="iface">
      <span class="sig">store.put(key, val)</span>
      <span class="sig">store.get(key)</span>
    </div>
    <div class="body">
      <div class="blabel">deep implementation</div>
      <ul>
        <li>LRU eviction &amp; TTL sweeps</li>
        <li>write-ahead log + crash recovery</li>
        <li>compaction, bloom filters, tiered flush</li>
        <li>concurrency: sharded locks, MVCC snapshots</li>
      </ul>
    </div>
  </div>
  <div class="note">Small surface area, large functionality hidden below.</div>
</div>
<style>
  .v-codebase-design{width:780px;box-sizing:border-box;padding:26px;background:#faf9f6;color:#17150f;font-family:system-ui,sans-serif;text-align:center;}
  .caption{font-family:"JetBrains Mono",monospace;font-size:12px;letter-spacing:.04em;color:#6b6559;text-transform:lowercase;margin-bottom:16px;}
  .module{display:inline-flex;flex-direction:column;align-items:center;width:100%;}
  .iface{width:300px;background:#17150f;color:#faf9f6;border-radius:8px 8px 0 0;padding:14px 0;display:flex;flex-direction:column;gap:6px;font-family:"JetBrains Mono",monospace;font-size:12.5px;}
  .sig{opacity:.92;}
  .body{width:100%;background:#fff;border:2px solid #17150f;border-radius:0 0 12px 12px;padding:22px 26px 26px;text-align:left;box-shadow:inset 0 -2px 0 #e5e1d8;}
  .blabel{font-family:"Newsreader",serif;font-size:17px;font-weight:600;margin-bottom:12px;text-align:center;color:#4a453b;}
  ul{list-style:none;margin:0;padding:0;columns:2;column-gap:34px;}
  li{position:relative;padding:7px 0 7px 18px;font-size:13px;color:#2a271f;break-inside:avoid;}
  li:before{content:"";position:absolute;left:0;top:13px;width:7px;height:7px;border-radius:2px;background:#c9c3b5;}
  .note{margin-top:16px;font-size:12.5px;color:#6b6559;font-style:italic;}
</style>
