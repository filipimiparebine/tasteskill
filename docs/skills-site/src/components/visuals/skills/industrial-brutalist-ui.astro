---
const { skill } = Astro.props;
---
<div class="v-industrial-brutalist-ui">
  <span class="ib-crop ib-tl"></span><span class="ib-crop ib-tr"></span>
  <span class="ib-crop ib-bl"></span><span class="ib-crop ib-br"></span>

  <div class="ib-head">
    <div>
      <p class="ib-doc">DOC//RM-04 · DECLASSIFIED</p>
      <h2 class="ib-title">THERMAL LOAD</h2>
    </div>
    <div class="ib-reg">
      <svg viewBox="0 0 30 30" width="30" height="30" aria-hidden="true">
        <circle cx="15" cy="15" r="9" fill="none" stroke="#f5a300" stroke-width="1"/>
        <line x1="15" y1="0" x2="15" y2="30" stroke="#f5a300" stroke-width="1"/>
        <line x1="0" y1="15" x2="30" y2="15" stroke="#f5a300" stroke-width="1"/>
      </svg>
    </div>
  </div>

  <div class="ib-grid">
    <div class="ib-cell">
      <span class="ib-k">CORE TEMP</span>
      <span class="ib-big">847<em>°C</em></span>
      <span class="ib-sub">Δ +12 / 60s</span>
    </div>
    <div class="ib-cell">
      <span class="ib-k">PRESSURE</span>
      <span class="ib-big">2.14<em>MPa</em></span>
      <span class="ib-sub">NOMINAL</span>
    </div>
    <div class="ib-cell ib-alert">
      <span class="ib-k">STATUS</span>
      <span class="ib-big ib-amber">HOLD</span>
      <span class="ib-sub">MANUAL OVERRIDE</span>
    </div>
  </div>

  <div class="ib-foot">
    <span>&gt; TRACE 0x1F..4C</span>
    <span class="ib-bars"><i></i><i></i><i></i><i></i><i></i><i></i><i></i></span>
    <span>SEQ 09/14</span>
  </div>
</div>

<style>
  .v-industrial-brutalist-ui {
    position: relative;
    background: #111008;
    color: #e8e6da;
    padding: 26px 28px;
    min-height: 400px;
    font-family: "JetBrains Mono", monospace;
    display: flex; flex-direction: column;
    border: 1px solid #2a2818;
  }
  .v-industrial-brutalist-ui::after {
    content: ""; position: absolute; inset: 0; pointer-events: none;
    background: repeating-linear-gradient(0deg, transparent 0, transparent 3px, rgba(255,255,255,.015) 3px, rgba(255,255,255,.015) 4px);
  }
  .ib-crop { position: absolute; width: 10px; height: 10px; border: 1px solid #f5a300; }
  .ib-tl { top: 8px; left: 8px; border-right: none; border-bottom: none; }
  .ib-tr { top: 8px; right: 8px; border-left: none; border-bottom: none; }
  .ib-bl { bottom: 8px; left: 8px; border-right: none; border-top: none; }
  .ib-br { bottom: 8px; right: 8px; border-left: none; border-top: none; }
  .ib-head { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 22px; }
  .ib-doc { margin: 0 0 6px; font-size: 10px; letter-spacing: 0.14em; color: #f5a300; }
  .ib-title { margin: 0; font-size: 46px; font-weight: 700; letter-spacing: -0.03em; line-height: 0.9; }
  .ib-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: #2a2818; border: 1px solid #2a2818; }
  .ib-cell { background: #17150c; padding: 16px 14px; display: flex; flex-direction: column; gap: 8px; }
  .ib-alert { background: #1c1608; }
  .ib-k { font-size: 10px; letter-spacing: 0.1em; color: #8f8b76; }
  .ib-big { font-size: 30px; font-weight: 700; letter-spacing: -0.02em; }
  .ib-big em { font-size: 13px; font-style: normal; color: #8f8b76; margin-left: 2px; }
  .ib-amber { color: #f5a300; }
  .ib-sub { font-size: 10px; letter-spacing: 0.08em; color: #6f6c5a; }
  .ib-foot { margin-top: auto; padding-top: 18px; display: flex; justify-content: space-between; align-items: center; font-size: 10px; letter-spacing: 0.06em; color: #8f8b76; }
  .ib-bars { display: flex; gap: 3px; align-items: flex-end; height: 14px; }
  .ib-bars i { width: 4px; background: #f5a300; }
  .ib-bars i:nth-child(1){height:40%} .ib-bars i:nth-child(2){height:90%} .ib-bars i:nth-child(3){height:60%}
  .ib-bars i:nth-child(4){height:100%} .ib-bars i:nth-child(5){height:30%} .ib-bars i:nth-child(6){height:70%}
  .ib-bars i:nth-child(7){height:50%}
</style>
