---
const { skill } = Astro.props;
---
<div class="v-brandkit">
  <div class="bk-head">
    <p class="bk-kicker">Brand Guidelines · v2</p>
    <h3 class="bk-name">HALCYON</h3>
  </div>
  <div class="bk-grid">
    <div class="bk-tile bk-mark">
      <svg viewBox="0 0 64 64" width="72" height="72" aria-hidden="true">
        <circle cx="32" cy="32" r="28" fill="none" stroke="#f2ede0" stroke-width="2"/>
        <path d="M20 44 L32 18 L44 44" fill="none" stroke="#f2ede0" stroke-width="4" stroke-linejoin="round"/>
        <line x1="25" y1="35" x2="39" y2="35" stroke="#c9a24a" stroke-width="4"/>
      </svg>
      <p class="bk-marklabel">Primary mark</p>
    </div>
    <div class="bk-tile bk-type">
      <p class="bk-tlabel">Typeface</p>
      <p class="bk-specimen">Aa</p>
      <p class="bk-tname">Newsreader — Display</p>
      <p class="bk-tset">ABCDEFGH · 0123456789</p>
    </div>
    <div class="bk-tile bk-palette">
      <p class="bk-tlabel">Palette</p>
      <div class="bk-swatches">
        <div class="bk-sw"><span style="background:#14130f"></span><em>#14130F</em></div>
        <div class="bk-sw"><span style="background:#c9a24a"></span><em>#C9A24A</em></div>
        <div class="bk-sw"><span style="background:#6b8f7d"></span><em>#6B8F7D</em></div>
        <div class="bk-sw"><span style="background:#f2ede0"></span><em>#F2EDE0</em></div>
      </div>
    </div>
  </div>
  <p class="bk-tagline">"Clarity, made quietly." — brand voice, first principle</p>
</div>

<style>
  .v-brandkit {
    background: #1b1a15; color: #f2ede0; padding: 26px 28px;
    font-family: "Newsreader", Georgia, serif; border-radius: 8px;
  }
  .bk-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 18px; }
  .bk-kicker { margin: 0; font-family: "JetBrains Mono", monospace; font-size: 10.5px; letter-spacing: .16em; text-transform: uppercase; color: #8f8a78; }
  .bk-name { margin: 0; font-size: 26px; font-weight: 600; letter-spacing: .28em; }
  .bk-grid { display: grid; grid-template-columns: 1fr 1fr 1.4fr; gap: 12px; }
  .bk-tile { background: #24231d; border: 1px solid #33311f; border-radius: 6px; padding: 18px; }
  .bk-mark { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px; }
  .bk-marklabel, .bk-tlabel { margin: 0; font-family: "JetBrains Mono", monospace; font-size: 9.5px; letter-spacing: .12em; text-transform: uppercase; color: #8f8a78; }
  .bk-type { display: flex; flex-direction: column; }
  .bk-tlabel { margin-bottom: 6px; }
  .bk-specimen { margin: 4px 0 8px; font-size: 56px; line-height: 1; font-weight: 500; letter-spacing: -.02em; color: #c9a24a; }
  .bk-tname { margin: 0 0 3px; font-size: 14px; }
  .bk-tset { margin: 0; font-family: "JetBrains Mono", monospace; font-size: 10px; color: #7d7869; }
  .bk-swatches { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 10px; }
  .bk-sw { display: flex; align-items: center; gap: 8px; }
  .bk-sw span { width: 26px; height: 26px; border-radius: 5px; display: block; border: 1px solid rgba(255,255,255,.08); flex: none; }
  .bk-sw em { font-style: normal; font-family: "JetBrains Mono", monospace; font-size: 11px; color: #cbc6b6; letter-spacing: .02em; }
  .bk-tagline { margin: 18px 0 0; font-size: 18px; font-style: italic; color: #ded8c6; }
</style>
