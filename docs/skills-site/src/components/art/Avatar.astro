---
// Round watercolour-bloom avatar with the artist's initials.
interface Props { initials: string; palette: string[]; seed?: number; size?: number; }
const { initials, palette = ["#e6c46b", "#eaa79b"], seed = 1, size = 36 } = Astro.props;
function mulberry32(a: number) { return function () { a |= 0; a = (a + 0x6d2b79f5) | 0; let t = Math.imul(a ^ (a >>> 15), 1 | a); t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t; return ((t ^ (t >>> 14)) >>> 0) / 4294967296; }; }
const r = mulberry32((seed * 40503) >>> 0);
const blobs = Array.from({ length: 4 }, () => ({ cx: 30 + r() * 40, cy: 30 + r() * 40, rr: 22 + r() * 18, fill: palette[Math.floor(r() * palette.length)], op: 0.6 + r() * 0.35 }));
const fid = `av-${seed}`;
---
<span class="aq-avatar" style={`width:${size}px;height:${size}px`}>
  <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <defs>
      <clipPath id={`clip-${seed}`}><circle cx="50" cy="50" r="50" /></clipPath>
      <filter id={fid}><feTurbulence type="fractalNoise" baseFrequency="0.02" numOctaves="2" seed={seed} result="n" /><feDisplacementMap in="SourceGraphic" in2="n" scale="12" /></filter>
    </defs>
    <g clip-path={`url(#clip-${seed})`}>
      <rect width="100" height="100" fill="var(--wc-paper, #f4efe3)" />
      <g filter={`url(#${fid})`} style="mix-blend-mode:multiply">
        {blobs.map((b) => <circle cx={b.cx} cy={b.cy} r={b.rr} fill={b.fill} opacity={b.op} />)}
      </g>
    </g>
  </svg>
  <em>{initials}</em>
</span>
