---
import WatercolorArt from "./WatercolorArt.astro";
import Avatar from "./Avatar.astro";
import { getArtist, type Artwork } from "../../data/art";
interface Props { work: Artwork }
const { work } = Astro.props;
const artist = getArtist(work.artist);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<article class="aq-card">
  <a class="aq-card-art" href={`${base}/aquarela/art/${work.slug}/`} aria-label={work.title}>
    <WatercolorArt seed={work.seed} palette={work.palette} />
    <span class="aq-card-medium">{work.medium}</span>
  </a>
  <div class="aq-card-meta">
    <div class="aq-card-lines">
      <a class="aq-card-title" href={`${base}/aquarela/art/${work.slug}/`}>{work.title}</a>
      <span class="aq-card-price">{work.priceRON} lei</span>
    </div>
    <a class="aq-card-artist" href={`${base}/aquarela/artist/${artist.slug}/`}>
      <Avatar initials={artist.initials} palette={artist.palette} seed={work.seed} size={30} />
      <span>{artist.alias}</span>
    </a>
  </div>
</article>
