---
import "../styles/global.css";
import Sidebar from "../components/Sidebar.astro";
const { title, current } = Astro.props as { title: string; current?: string };
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta
      name="description"
      content="A reference catalogue of the Claude Code skills installed in this repo — what each does and how it looks."
    />
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;1,6..72,400&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --font-serif: "Newsreader", Georgia, serif;
        --font-mono: "JetBrains Mono", ui-monospace, monospace;
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <Sidebar current={current} />
      <main class="content">
        <slot />
      </main>
    </div>
  </body>
</html>
